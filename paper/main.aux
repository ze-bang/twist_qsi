\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces (a) The winding four-loop scale $g_{4}$ (second order) exceeds the physical photon scale $g_{\mathrm  {hex}}$ (third order) throughout the perturbative regime, their ratio diverging as $J_{\pm }\to 0$. (b) Fraction of each geometric channel's coupling retained: boundary-twist averaging keeps half of every winding artifact, whereas the zero-transport ($\bm  {\delta }=0$) projection removes them and keeps the physical hexagon at full strength.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:concept}{{1}{2}{(a) The winding four-loop scale $\gfour $ (second order) exceeds the physical photon scale $\ghex $ (third order) throughout the perturbative regime, their ratio diverging as $\Jpm \to 0$. (b) Fraction of each geometric channel's coupling retained: boundary-twist averaging keeps half of every winding artifact, whereas the zero-transport ($\bdelta =0$) projection removes them and keeps the physical hexagon at full strength}{figure.1}{}}
\@writefile{toc}{\contentsline {paragraph}{\numberline {}Why twist averaging is insufficient.}{2}{section*.6}\protected@file@percent }
